{
  "manifest_version": 3,
  "name": "DOT/Mermaid Viewer",
  "version": "1.0",
  "description": "DOT言語とMermaid記法に対応したグラフ描画・確認ツール",
  "action": {
    "default_icon": {
      "16": "images/dot_mermaid.png",
      "48": "images/dot_mermaid.png",
      "128": "images/dot_mermaid.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "windows",
    "system.display"
  ],
  "icons": {
    "16": "images/dot_mermaid.png",
    "48": "images/dot_mermaid.png",
    "128": "images/dot_mermaid.png"
  }
}
